SECRET_KEY=change-me-to-a-random-string
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=change-me
FLASK_DEBUG=0
PORT=5000

# Redis（Docker 部署时自动配置，本地开发可留空则回退到文件 Session）
REDIS_URL=redis://localhost:6379/0

# HTTPS 配置（运行 deploy/init-letsencrypt.sh 时使用）
# DOMAIN=exam.example.com
# CERTBOT_EMAIL=admin@example.com

# 启用 HTTPS 后设置此变量并重启 nginx:
# NGINX_CONF=./deploy/nginx.ssl.conf
